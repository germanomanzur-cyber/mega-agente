# ── OpenAI ────────────────────────────────────────────────────────────────────
# Obtené tu clave en: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Meta / WhatsApp Cloud API ──────────────────────────────────────────────────
# 1. Creá una app en: https://developers.facebook.com
# 2. Activá el producto "WhatsApp" en tu app
# 3. El PHONE_NUMBER_ID lo encontrás en: WhatsApp > API Setup
# 4. El ACCESS_TOKEN se genera en el mismo panel (usá un token permanente para producción)

WHATSAPP_PHONE_NUMBER_ID=1234567890123456
WHATSAPP_ACCESS_TOKEN=EAAxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Webhook ────────────────────────────────────────────────────────────────────
# Este token lo inventás vos y lo pegás IGUAL en el panel de Meta al configurar el webhook
VERIFY_TOKEN=mega_inmobiliaria_token

# ── Servidor ───────────────────────────────────────────────────────────────────
PORT=3000
